{
  "name": "admin",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.local -o -- next dev --port 3001",
    "start:e2e": "node ../../scripts/dev-test-server.mjs admin 3003 admin.session-token",
    "build": "pnpm --filter @repo/db exec prisma generate && next build",
    "start": "next start --port 3001",
    "lint": "eslint --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@libsql/client": "^0.8.0",
    "@prisma/adapter-libsql": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@repo/auth": "workspace:^",
    "@repo/db": "workspace:*",
    "@soundwave/ui": "workspace:*",
    "next": "14.2.29",
    "next-auth": "5.0.0-beta.31",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "dotenv-cli": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "5.9.2"
  }
}
