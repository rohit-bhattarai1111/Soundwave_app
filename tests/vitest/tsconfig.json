{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "../../apps/store/*",
        "../../apps/admin/*"
      ]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
