{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./client":  "./src/client.ts",
    "./seed":    "./src/seed.ts",
    "./data":    "./src/data.ts",
    "./pricing":   "./src/pricing.ts",
    "./order-item": "./src/order-item.ts"
  },
  "scripts": {
    "postinstall": "prisma generate && node scripts/sync-prisma-client.mjs",
    "db:migrate":        "prisma migrate dev",
    "db:migrate:turso":  "tsx src/migrate-turso.ts",
    "db:fix:sale-column": "tsx src/fix-sale-column.ts",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate && node scripts/sync-prisma-client.mjs",
    "db:seed":     "prisma db seed",
    "db:studio":   "prisma studio",
    "db:reset":    "prisma migrate reset --force"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@libsql/client":          "^0.8.0",
    "@prisma/adapter-libsql":  "^5.22.0",
    "@prisma/client":          "^5.22.0",
    "bcryptjs":                "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "dotenv":          "^16.4.7",
    "prisma":          "^5.22.0",
    "tsx":             "^4.19.2",
    "typescript":      "5.9.2"
  }
}
